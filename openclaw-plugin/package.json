{
  "name": "@happyikas/openclaw-plugin-aegis",
  "version": "0.2.0-preview.2",
  "description": "OpenClaw plugin that runs every tool call through Aegis ATV's 16-step firewall + cryptographic audit chain. Multi-channel attribution + provider drift detection (preview).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "openclaw.plugin.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "aegis",
    "firewall",
    "audit",
    "agent",
    "security"
  ],
  "author": "Aegis ATV contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happyikas/Aegis-ATV.git",
    "directory": "openclaw-plugin"
  },
  "homepage": "https://github.com/happyikas/Aegis-ATV/tree/main/openclaw-plugin",
  "bugs": "https://github.com/happyikas/Aegis-ATV/issues",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
