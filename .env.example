ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ATV
AEGIS_ATV_VERSION=ATV-2080-v1
AEGIS_TENANT_DEFAULT=demo-tenant

# Embedding (openai | dummy | bge-local)
AEGIS_EMBEDDING_PROVIDER=dummy
AEGIS_EMBEDDING_MODEL=text-embedding-3-small

# Judge (haiku | dummy | local-phi)
AEGIS_JUDGE_PROVIDER=dummy
AEGIS_JUDGE_TEMPERATURE=0.0
AEGIS_JUDGE_SEED=42

# Pre-LLM safety classifier — populates safety_flags from real text on the
# host BEFORE POSTing to /evaluate. Read by tools/aegis_safety.py.
#   dummy  - regex heuristics, offline, free, default
#   openai - OpenAI omni-moderation-latest (needs OPENAI_API_KEY)
#   haiku  - Claude Haiku 3.5 as JSON classifier (needs ANTHROPIC_API_KEY,
#            ~$0.001/call, best for prompt-injection nuance)
AEGIS_SAFETY_PROVIDER=dummy

# Signing
AEGIS_SIGNING_KEY_PATH=./keys/ed25519.pem
AEGIS_PUBLIC_KEY_PATH=./keys/ed25519.pub

# Audit
AEGIS_AUDIT_DB=./data/audit.sqlite
AEGIS_AUDIT_JSONL=./data/audit.jsonl

# Policy
AEGIS_POLICY_DIR=./policies
